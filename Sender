#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <errno.h>
#include <stdint.h>
#include <arpa/inet.h>
#include <sys/socket.h>
#include <sys/select.h>
#include <netinet/in.h>

#define HARNESS_RECV_PORT   47010
#define RELAY_SEND_PORT     47001
#define FEEDBACK_RECV_PORT  47004
#define RELAY_HOST          "127.0.0.1"

#define PAYLOAD_LEN         160
#define FRAME_LEN           (4 + PAYLOAD_LEN)   /* harness wire frame */

#define FLAG_HAS_RED        0x02
#define NACK_MARKER         0xE0

#define DATA_PKT_MAX        (1 + 4 + PAYLOAD_LEN + PAYLOAD_LEN)

/* Ring buffer of recently-sent frames, so we can answer NACKs and
 * build the piggyback redundancy field without re-reading old data.
 * 512 slots * 20ms = ~10.2s of history, far more than any sane NACK
 * round trip time, at a trivial memory cost (~82KB). */
#define HIST_SIZE 512

typedef struct {
    uint8_t  payload[PAYLOAD_LEN];
    uint32_t seq;
    int      valid;
} hist_entry_t;

static hist_entry_t g_history[HIST_SIZE];

static void hist_put(uint32_t seq, const uint8_t *payload) {
    hist_entry_t *e = &g_history[seq % HIST_SIZE];
    e->seq = seq;
    memcpy(e->payload, payload, PAYLOAD_LEN);
    e->valid = 1;
}

/* Returns 1 and fills payload if we still have it, else 0. */
static int hist_get(uint32_t seq, uint8_t *payload) {
    hist_entry_t *e = &g_history[seq % HIST_SIZE];
    if (e->valid && e->seq == seq) {
        memcpy(payload, e->payload, PAYLOAD_LEN);
        return 1;
    }
    return 0;
}

static int make_udp_socket(void) {
    int fd = socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) { perror("socket"); exit(1); }
    return fd;
}

int main(void) {
    int harness_fd = make_udp_socket();
    int relay_fd    = make_udp_socket();
    int fb_fd       = make_udp_socket();

    struct sockaddr_in harness_addr;
    memset(&harness_addr, 0, sizeof(harness_addr));
    harness_addr.sin_family = AF_INET;
    harness_addr.sin_addr.s_addr = INADDR_ANY;
    harness_addr.sin_port = htons(HARNESS_RECV_PORT);
    if (bind(harness_fd, (struct sockaddr *)&harness_addr, sizeof(harness_addr)) < 0) {
        perror("bind harness_fd"); exit(1);
    }

    struct sockaddr_in fb_addr;
    memset(&fb_addr, 0, sizeof(fb_addr));
    fb_addr.sin_family = AF_INET;
    fb_addr.sin_addr.s_addr = INADDR_ANY;
    fb_addr.sin_port = htons(FEEDBACK_RECV_PORT);
    if (bind(fb_fd, (struct sockaddr *)&fb_addr, sizeof(fb_addr)) < 0) {
        perror("bind fb_fd"); exit(1);
    }

    struct sockaddr_in relay_addr;
    memset(&relay_addr, 0, sizeof(relay_addr));
    relay_addr.sin_family = AF_INET;
    relay_addr.sin_port = htons(RELAY_SEND_PORT);
    inet_pton(AF_INET, RELAY_HOST, &relay_addr.sin_addr);

    uint32_t last_seq = 0;
    int have_last = 0;

    for (;;) {
        fd_set rfds;
        FD_ZERO(&rfds);
        FD_SET(harness_fd, &rfds);
        FD_SET(fb_fd, &rfds);
        int maxfd = harness_fd > fb_fd ? harness_fd : fb_fd;

        /* Short timeout just keeps the loop responsive; both fds are
         * also directly selected on so this mostly just bounds how
         * quickly we notice shutdown/errors. */
        struct timeval tv = {0, 5000};
        int rv = select(maxfd + 1, &rfds, NULL, NULL, &tv);
        if (rv < 0) {
            if (errno == EINTR) continue;
            perror("select");
            break;
        }

        /* --- Handle NACKs first: retransmission is time-critical --- */
        if (rv > 0 && FD_ISSET(fb_fd, &rfds)) {
            uint8_t buf[8];
            struct sockaddr_in src;
            socklen_t slen = sizeof(src);
            ssize_t n = recvfrom(fb_fd, buf, sizeof(buf), 0,
                                  (struct sockaddr *)&src, &slen);
            if (n >= 5 && buf[0] == NACK_MARKER) {
                uint32_t miss_seq;
                memcpy(&miss_seq, buf + 1, 4);
                miss_seq = ntohl(miss_seq);

                uint8_t payload[PAYLOAD_LEN];
                if (hist_get(miss_seq, payload)) {
                    uint8_t pkt[DATA_PKT_MAX];
                    uint32_t seq_be = htonl(miss_seq);
                    pkt[0] = 0; /* no piggyback on a retransmit; keep it small */
                    memcpy(pkt + 1, &seq_be, 4);
                    memcpy(pkt + 5, payload, PAYLOAD_LEN);
                    sendto(relay_fd, pkt, 5 + PAYLOAD_LEN, 0,
                           (struct sockaddr *)&relay_addr, sizeof(relay_addr));
                }
            }
        }

        /* --- Handle a new frame from the harness source --- */
        if (rv > 0 && FD_ISSET(harness_fd, &rfds)) {
            uint8_t buf[FRAME_LEN];
            struct sockaddr_in src;
            socklen_t slen = sizeof(src);
            ssize_t n = recvfrom(harness_fd, buf, sizeof(buf), 0,
                                  (struct sockaddr *)&src, &slen);
            if (n == FRAME_LEN) {
                uint32_t seq;
                memcpy(&seq, buf, 4);
                seq = ntohl(seq);
                const uint8_t *payload = buf + 4;

                hist_put(seq, payload);

                uint8_t pkt[DATA_PKT_MAX];
                uint32_t seq_be = htonl(seq);
                size_t pkt_len;

                uint8_t red_payload[PAYLOAD_LEN];
                int has_red = have_last && hist_get(last_seq, red_payload)
                              && last_seq == seq - 1;

                pkt[0] = has_red ? FLAG_HAS_RED : 0;
                memcpy(pkt + 1, &seq_be, 4);
                memcpy(pkt + 5, payload, PAYLOAD_LEN);
                if (has_red) {
                    memcpy(pkt + 5 + PAYLOAD_LEN, red_payload, PAYLOAD_LEN);
                    pkt_len = 5 + PAYLOAD_LEN + PAYLOAD_LEN;
                } else {
                    pkt_len = 5 + PAYLOAD_LEN;
                }

                sendto(relay_fd, pkt, pkt_len, 0,
                       (struct sockaddr *)&relay_addr, sizeof(relay_addr));

                last_seq = seq;
                have_last = 1;
            }
        }
    }

    close(harness_fd);
    close(relay_fd);
    close(fb_fd);
    return 0;
}
