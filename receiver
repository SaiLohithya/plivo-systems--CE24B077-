
 *     - the real frame, if it has arrived,
 *     - otherwise a concealment frame (repeat of last good payload),
 *       so playback timing never stalls waiting on the network.
 * - Duplicate packets (any seq <= last delivered, or already stored)
 *   are silently dropped.
 * - Late-but-not-yet-played gaps trigger a single NACK back to the
 *   sender as soon as the gap is noticed (not at playout deadline),
 *   maximizing the time available for a retransmit to land before
 *   concealment has to kick in.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <errno.h>
#include <stdint.h>
#include <pthread.h>
#include <time.h>
#include <arpa/inet.h>
#include <sys/socket.h>
#include <netinet/in.h>

#define RELAY_RECV_PORT     47002
#define PLAYER_SEND_PORT    47020
#define FEEDBACK_SEND_PORT  47003
#define RELAY_HOST          "127.0.0.1"

#define PAYLOAD_LEN         160
#define FRAME_LEN           (4 + PAYLOAD_LEN)

#define FLAG_HAS_RED        0x02
#define NACK_MARKER         0xE0

/* How many frames of buffering we insert before starting playout.
 * 4 frames = 80ms. This is the main knob for the delay/robustness
 * trade-off called out in NOTES.md. */
#define JITTER_FRAMES        4
#define FRAME_MS             20

/* Ring buffer sized well beyond the jitter depth so out-of-order or
 * redundancy-recovered frames that arrive "early" always have room. */
#define BUF_SIZE            1024

typedef struct {
    uint8_t  payload[PAYLOAD_LEN];
    uint32_t seq;
    int      valid;
    int      nack_sent;   /* avoid spamming NACKs for the same gap */
} buf_entry_t;

static buf_entry_t g_buf[BUF_SIZE];
static pthread_mutex_t g_lock = PTHREAD_MUTEX_INITIALIZER;

static int      g_started = 0;      /* has playout been scheduled yet */
static uint32_t g_next_play_seq = 0;
static uint32_t g_highest_seen = 0;
static int      g_have_highest = 0;

static int g_player_fd, g_fb_fd;
static struct sockaddr_in g_player_addr, g_fb_addr;

static uint8_t g_last_played[PAYLOAD_LEN];
static int     g_have_last_played = 0;

static inline buf_entry_t *slot(uint32_t seq) { return &g_buf[seq % BUF_SIZE]; }

static void store_frame(uint32_t seq, const uint8_t *payload) {
    buf_entry_t *e = slot(seq);
    /* A stale slot (very old seq, wrapped around) or a fresh one:
     * either way just overwrite -- consumers only trust it when
     * e->seq == the seq they're looking for. */
    e->seq = seq;
    memcpy(e->payload, payload, PAYLOAD_LEN);
    e->valid = 1;
    e->nack_sent = 0;
}

static void send_nack(uint32_t seq) {
    uint8_t pkt[5];
    uint32_t seq_be = htonl(seq);
    pkt[0] = NACK_MARKER;
    memcpy(pkt + 1, &seq_be, 4);
    sendto(g_fb_fd, pkt, sizeof(pkt), 0,
           (struct sockaddr *)&g_fb_addr, sizeof(g_fb_addr));
}

static void send_to_player(uint32_t seq, const uint8_t *payload) {
    uint8_t pkt[FRAME_LEN];
    uint32_t seq_be = htonl(seq);
    memcpy(pkt, &seq_be, 4);
    memcpy(pkt + 4, payload, PAYLOAD_LEN);
    sendto(g_player_fd, pkt, FRAME_LEN, 0,
           (struct sockaddr *)&g_player_addr, sizeof(g_player_addr));
}

/* --- Network receive thread --------------------------------------- */

static void *recv_thread(void *arg) {
    (void)arg;
    int relay_fd = socket(AF_INET, SOCK_DGRAM, 0);
    if (relay_fd < 0) { perror("socket relay_fd"); exit(1); }

    struct sockaddr_in relay_bind;
    memset(&relay_bind, 0, sizeof(relay_bind));
    relay_bind.sin_family = AF_INET;
    relay_bind.sin_addr.s_addr = INADDR_ANY;
    relay_bind.sin_port = htons(RELAY_RECV_PORT);
    if (bind(relay_fd, (struct sockaddr *)&relay_bind, sizeof(relay_bind)) < 0) {
        perror("bind relay_fd"); exit(1);
    }

    uint8_t buf[1 + 4 + PAYLOAD_LEN + PAYLOAD_LEN];

    for (;;) {
        ssize_t n = recvfrom(relay_fd, buf, sizeof(buf), 0, NULL, NULL);
        if (n < (ssize_t)(5 + PAYLOAD_LEN)) continue; /* too short to be valid */

        uint8_t  flags = buf[0];
        uint32_t seq;
        memcpy(&seq, buf + 1, 4);
        seq = ntohl(seq);
        const uint8_t *payload = buf + 5;

        int has_red = (flags & FLAG_HAS_RED) &&
                      (n >= (ssize_t)(5 + PAYLOAD_LEN + PAYLOAD_LEN));
        const uint8_t *red_payload = has_red ? buf + 5 + PAYLOAD_LEN : NULL;

        pthread_mutex_lock(&g_lock);

        if (!g_started) {
            /* First frame we've ever seen: anchor the playout schedule
             * JITTER_FRAMES behind it so we get some buffering headroom. */
            g_next_play_seq = seq;
            g_started = 1;
        }

        if (seq >= g_next_play_seq) {
            /* Only bother storing frames we haven't already played. */
            if (!(slot(seq)->valid && slot(seq)->seq == seq)) {
                store_frame(seq, payload);
            }
            if (has_red && seq > 0) {
                uint32_t rseq = seq - 1;
                if (rseq >= g_next_play_seq &&
                    !(slot(rseq)->valid && slot(rseq)->seq == rseq)) {
                    store_frame(rseq, red_payload);
                }
            }
        }
        /* else: seq < g_next_play_seq -> late arrival or duplicate of an
         * already-played frame. Drop it; concealment already ran. */

        if (!g_have_highest || seq > g_highest_seen) {
            g_have_highest = 1;
            g_highest_seen = seq;
        }

        /* Gap detection: for every seq between next_play_seq and the
         * new highest seen that's still missing, ask for a retransmit
         * once. Bounded loop: only walks the current known gap. */
        for (uint32_t s = g_next_play_seq;
             s != seq && s < seq && (seq - s) < BUF_SIZE;
             s++) {
            buf_entry_t *e = slot(s);
            if (!(e->valid && e->seq == s) && !e->nack_sent) {
                e->nack_sent = 1;
                pthread_mutex_unlock(&g_lock);
                send_nack(s);
                pthread_mutex_lock(&g_lock);
            }
        }

        pthread_mutex_unlock(&g_lock);
    }
    return NULL;
}

/* --- Playout thread -------------------------------------------------
 * Runs on an absolute-time 20ms schedule so timing doesn't drift even
 * if individual iterations take a little longer than expected. */

static void ts_add_ms(struct timespec *ts, long ms) {
    ts->tv_nsec += ms * 1000000L;
    while (ts->tv_nsec >= 1000000000L) {
        ts->tv_nsec -= 1000000000L;
        ts->tv_sec += 1;
    }
}

static void *playout_thread(void *arg) {
    (void)arg;

    /* Wait until playout has been anchored by the first received frame. */
    for (;;) {
        pthread_mutex_lock(&g_lock);
        int started = g_started;
        pthread_mutex_unlock(&g_lock);
        if (started) break;
        struct timespec wait_ts = {0, 1000000L}; /* 1ms */
        nanosleep(&wait_ts, NULL);
    }

    struct timespec next;
    clock_gettime(CLOCK_MONOTONIC, &next);
    /* Insert the jitter buffer delay before the very first tick. */
    ts_add_ms(&next, JITTER_FRAMES * FRAME_MS);

    for (;;) {
        clock_nanosleep(CLOCK_MONOTONIC, TIMER_ABSTIME, &next, NULL);

        pthread_mutex_lock(&g_lock);
        uint32_t seq = g_next_play_seq;
        buf_entry_t *e = slot(seq);
        int have_it = (e->valid && e->seq == seq);
        uint8_t payload[PAYLOAD_LEN];

        if (have_it) {
            memcpy(payload, e->payload, PAYLOAD_LEN);
            e->valid = 0; /* consumed */
        } else if (g_have_last_played) {
            /* Simple packet-loss concealment: repeat the last good
             * frame rather than sending silence or stalling. Keeps
             * playout cadence perfectly regular. */
            memcpy(payload, g_last_played, PAYLOAD_LEN);
        } else {
            memset(payload, 0, PAYLOAD_LEN); /* silence before first frame */
        }

        memcpy(g_last_played, payload, PAYLOAD_LEN);
        g_have_last_played = 1;
        g_next_play_seq = seq + 1;
        pthread_mutex_unlock(&g_lock);

        send_to_player(seq, payload);

        ts_add_ms(&next, FRAME_MS);
    }
    return NULL;
}

int main(void) {
    g_player_fd = socket(AF_INET, SOCK_DGRAM, 0);
    g_fb_fd     = socket(AF_INET, SOCK_DGRAM, 0);
    if (g_player_fd < 0 || g_fb_fd < 0) { perror("socket"); exit(1); }

    memset(&g_player_addr, 0, sizeof(g_player_addr));
    g_player_addr.sin_family = AF_INET;
    g_player_addr.sin_port = htons(PLAYER_SEND_PORT);
    inet_pton(AF_INET, RELAY_HOST, &g_player_addr.sin_addr);

    memset(&g_fb_addr, 0, sizeof(g_fb_addr));
    g_fb_addr.sin_family = AF_INET;
    g_fb_addr.sin_port = htons(FEEDBACK_SEND_PORT);
    inet_pton(AF_INET, RELAY_HOST, &g_fb_addr.sin_addr);

    pthread_t t_recv, t_play;
    pthread_create(&t_recv, NULL, recv_thread, NULL);
    pthread_create(&t_play, NULL, playout_thread, NULL);

    pthread_join(t_recv, NULL);
    pthread_join(t_play, NULL);
    return 0;
}
